# PTA API URLs
PTA_SUBMIT_URL=https://pintia.cn/api/problem-sets/YOUR_PROBLEM_SET_ID/submissions
PTA_PROBLEM_URL=https://pintia.cn/api/problem-sets/YOUR_PROBLEM_SET_ID/problem-types
PTA_RANK_URL=https://pintia.cn/api/problem-sets/YOUR_PROBLEM_SET_ID/common-rankings
PTA_REFERER_BASE_URL=https://pintia.cn/problem-sets/YOUR_PROBLEM_SET_ID
PTA_SUBMISSIONS_REFERER_PATH=submissions
PTA_RANKINGS_REFERER_PATH=rankings

# PTA Cookies
PTA_COOKIE="PTASession=xxx; _bl_uid=xxx; JSESSIONID=xxx"

# PTA Request Headers
PTA_X_LOLLIPOP=your_lollipop
PTA_X_MARSHMALLOW=
PTA_ACCEPT=application/json;charset=UTF-8
PTA_ACCEPT_ENCODING=gzip, deflate, br, zstd
PTA_ACCEPT_LANGUAGE=zh-CN
PTA_CONTENT_TYPE=application/json;charset=UTF-8
PTA_PRIORITY=u=1, i
PTA_SEC_CH_UA="Chromium";v="146", "Not-A.Brand";v="24", "Microsoft Edge";v="146"
PTA_SEC_CH_UA_MOBILE=?0
PTA_SEC_CH_UA_PLATFORM="Windows"
PTA_SEC_FETCH_DEST=empty
PTA_SEC_FETCH_MODE=cors
PTA_SEC_FETCH_SITE=same-origin
PTA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36 Edg/146.0.0.0

# PTA Request Params
PTA_SUBMIT_LIMIT=1000
PTA_SUBMIT_FILTER={}
PTA_PROBLEM_PARAMS_JSON={}
PTA_RANK_PAGE=0
PTA_RANK_LIMIT=100
PTA_SUBMIT_TIMEOUT_SECONDS=10
PTA_PROBLEM_TIMEOUT_SECONDS=15
PTA_RANK_TIMEOUT_SECONDS=15
PTA_ALLOW_REDIRECTS=true

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=49.234.197.24:9092
KAFKA_SUBMISSION_TOPIC=acm.board.submission.events
KAFKA_BROADCAST_TOPIC=acm.board.submission.events
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3
KAFKA_SEND_TIMEOUT_SECONDS=10
SUBMISSION_POLL_INTERVAL_SECONDS=5

# App Configuration
APP_TITLE=ACM Show Submit API
APP_SOURCE_NAME=acm_board_backend
APP_HOST=0.0.0.0
APP_PORT=8090
APP_RELOAD=false
ADMIN_HTML_FILE=admin.html

# First Blood Configuration
FIRST_BLOOD_PROBLEM_IDS=A,B,C,D,E,F,G,H,I,J,K,L
FIRST_BLOOD_EMPTY_VALUE=-1

# Database Configuration
DB_FILE=acm_board.db

# Migration Configuration
MIGRATION_SUBMISSION_IDS_CSV=submissionIds.csv
MIGRATION_STUDENT_PASSED_PROBLEMS_CSV=student_passed_problems.csv
MIGRATION_USER_PROBLEM_CSV=user_problem.csv
MIGRATION_PROBLEM_LABEL_CSV=problem_label.csv
MIGRATION_USER_INFO_CSV=user_info.csv
MIGRATION_ID_INFO_CSV=id_info.csv
